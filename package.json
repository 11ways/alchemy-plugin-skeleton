{
	"name"            : "alchemy-thoth",
	"description"     : "The Thoth AI plugin for Alchemy - includes LLM client and MCP server support",
	"author"          : "Jelle De Loecker <jelle@elevenways.be>",
	"version"         : "0.2.2",
	"repository"      : "11ways/alchemy-thoth",
	"license"         : "MIT",
	"keywords"        : ["alchemymvc", "ai", "llm", "mcp", "model-context-protocol"],
	"contributors"    : [],
	"dependencies"    : {},
	"optionalDependencies": {
		"@modelcontextprotocol/sdk": "~1.25.0"
	},
	"devDependencies" : {
		"alchemymvc"    : ">=1.4.0",
		"alchemy-acl"   : ">=0.9.0",
		"alchemy-form"  : ">=0.3.0",
		"codecov"       : "~3.7.2",
		"mocha"         : "~8.0.1",
		"mongo-unit"    : "~3.3.0",
		"nyc"           : "^15.1.0",
		"@modelcontextprotocol/sdk": "~1.25.0"
	},
	"peerDependencies": {
		"alchemymvc" : ">=1.4.0"
	},
	"scripts": {
		"test"            : "node_modules/.bin/mocha --exit --reporter spec --bail --timeout 5000 --file test/00-init.js",
		"appveyor"        : "node_modules/.bin/mocha --exit --reporter spec --bail --timeout 20000 --file test/00-init.js",
		"coverage"        : "node_modules/.bin/nyc --reporter=text --reporter=lcov mocha --exit --timeout 20000 --bail --file test/00-init.js",
		"report-coverage" : "cat ./coverage/lcov.info | codecov"
	},
	"engines": {
		"node": ">=18.0.0"
	}
}
